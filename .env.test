# Test Environment Configuration
# This file contains environment variables for the isolated test environment
# All services use different ports than the development environment

# =============================================================================
# PostgreSQL Test Configuration (Port 5433)
# =============================================================================
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password
POSTGRES_DB=test_main_server
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# =============================================================================
# MongoDB Test Configuration (Port 27018)
# =============================================================================
MONGO_INITDB_ROOT_USERNAME=test_root
MONGO_INITDB_ROOT_PASSWORD=test_root_password
MONGO_CONFIG_USERNAME=test_config_user
MONGO_CONFIG_PASSWORD=test_config_password
MONGO_TASK_USERNAME=test_task_user
MONGO_TASK_PASSWORD=test_task_password
MONGO_CONFIG_DB=test_config_server
MONGO_TASK_DB=test_task_server
MONGO_HOST=localhost
MONGO_PORT=27018

# =============================================================================
# Redis Test Configuration (Port 6380)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=test_password

# =============================================================================
# RabbitMQ Test Configuration (Port 5673)
# =============================================================================
RABBITMQ_DEFAULT_USER=test_user
RABBITMQ_DEFAULT_PASS=test_password
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_MANAGEMENT_PORT=15673

# =============================================================================
# MinIO Test Configuration (Port 9010)
# =============================================================================
MINIO_ROOT_USER=test_minio_user
MINIO_ROOT_PASSWORD=test_minio_password
MINIO_HOST=localhost
MINIO_PORT=9010
MINIO_CONSOLE_PORT=9011
MINIO_ACCESS_KEY_ID=test_minio_user
MINIO_SECRET_ACCESS_KEY=test_minio_password
MINIO_USE_SSL=false
MINIO_BUCKET=test-bucket
MINIO_ENDPOINT=localhost:9010

# =============================================================================
# Main-Server Test Configuration
# =============================================================================
MAIN_SERVER_API_URL=http://localhost:8080
MAIN_SERVER_PORT=8080
MAIN_SERVER_DATABASE_URL=postgres://test_user:test_password@localhost:5433/test_main_server?sslmode=disable
MAIN_SERVER_COOKIE_DOMAIN=localhost
MAIN_SERVER_FRONTEND_URL=http://localhost:3000
MAIN_SERVER_DEV_MODE=true

# Test JWT Secrets (different from production)
MAIN_SERVER_JWT_SECRET=test_jwt_secret_key_for_testing_only_12345
MAIN_SERVER_JWT_REFRESH_SECRET=test_jwt_refresh_secret_for_testing_only_67890

# Test Google OAuth2 (use test credentials or mock)
MAIN_SERVER_GOOGLE_CLIENT_ID=test_google_client_id
MAIN_SERVER_GOOGLE_CLIENT_SECRET=test_google_client_secret

# Test S3/MinIO Configuration
MAIN_SERVER_S3_ACCESS_KEY_ID=test_minio_user
MAIN_SERVER_S3_SECRET_ACCESS_KEY=test_minio_password
MAIN_SERVER_S3_USE_SSL=false
MAIN_SERVER_S3_BUCKET=test-bucket
MAIN_SERVER_S3_ENDPOINT=localhost:9010
MAIN_SERVER_S3_FRONTEND_URL=http://localhost:9010

# Test Service URLs (point to test infrastructure)
MAIN_SERVER_CONFIG_SERVER_URL=localhost:8081
MAIN_SERVER_GRADER_SERVER_URL=localhost:8083
MAIN_SERVER_TASK_SERVER_URL=localhost:8082
MAIN_SERVER_RBMQ_SERVER_URL=amqp://test_user:test_password@localhost:5673/
MAIN_SERVER_REDIS_SERVER_URL=redis://:test_password@localhost:6380

# =============================================================================
# Config-Server Test Configuration
# =============================================================================
CONFIG_SERVER_PORT=8081
CONFIG_SERVER_MONGO_URI=mongodb://test_config_user:test_config_password@localhost:27018/test_config_server
MONGO_CONFIG_DB=test_config_server
CONFIG_SERVER_TASK_SERVER_URL=http://localhost:8082
CONFIG_SERVER_GO_GRADER_SERVER_URL=http://localhost:8083
CONFIG_SERVER_REDIS_SERVER_URL=redis://:test_password@localhost:6380
CONFIG_SERVER_REDIS_PASSWORD=test_password

# =============================================================================
# Task-Server Test Configuration
# =============================================================================
TASK_SERVER_PORT=8082
TASK_SERVER_MONGO_URI=mongodb://test_task_user:test_task_password@localhost:27018/test_task_server
MONGO_TASK_DB=test_task_server
TASK_SERVER_GRADER_SERVER_URL=http://localhost:8083
TASK_SERVER_REDIS_SERVER_URL=redis://:test_password@localhost:6380
TASK_SERVER_REDIS_PASSWORD=test_password

# =============================================================================
# Go-Grader Test Configuration
# =============================================================================
GO_GRADER_PORT=8083
GO_GRADER_RBMQ_SERVER_URL=amqp://test_user:test_password@localhost:5673/
GO_GRADER_CONFIG_SERVER_URL=http://localhost:8081
GO_GRADER_TASK_SERVER_URL=http://localhost:8082

# =============================================================================
# Test Database URLs (for direct connections)
# =============================================================================
TEST_DATABASE_URL=postgres://test_user:test_password@localhost:5433/test_main_server?sslmode=disable
TEST_MONGO_CONFIG_URI=mongodb://test_config_user:test_config_password@localhost:27018/test_config_server
TEST_MONGO_TASK_URI=mongodb://test_task_user:test_task_password@localhost:27018/test_task_server
TEST_REDIS_URL=redis://:test_password@localhost:6380
TEST_RABBITMQ_URL=amqp://test_user:test_password@localhost:5673/
TEST_MINIO_ENDPOINT=localhost:9010

# =============================================================================
# Test Flags
# =============================================================================
TEST_ENV=true
CI=false
