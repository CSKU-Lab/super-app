# syntax=docker/dockerfile:1
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/mcp-server ./cmd/mcp-server

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/mcp-server /mcp-server
EXPOSE 8090
USER nonroot:nonroot
ENTRYPOINT ["/mcp-server"]
# http is the default (prod) transport; overridden via flags/env if needed.
CMD ["--transport=http", "--addr=:8090"]
