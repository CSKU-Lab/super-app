{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "coordinator": {
      "description": "Routes feature requests to specialist agents, creates GitHub issues, manages workflow orchestration",
      "mode": "primary",
      "temperature": 0.3,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "gh issue create": "allow",
          "gh pr view": "allow",
          "git log": "allow",
          "git status": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "allow"
        }
      },
      "prompt": "{file:./.opencode/agents/coordinator.md}"
    },
    "go-clean-arch": {
      "description": "Implements Go services following clean architecture - domain logic, services, handlers, unit tests",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git push --force": "deny"
        },
        "webfetch": "deny",
        "task": "deny"
      },
      "prompt": "{file:./.opencode/agents/go-clean-arch.md}"
    },
    "db-design-impl": {
      "description": "Database design and implementation - schemas, migrations, integration tests, fixtures, mock gRPC stubs",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git push --force": "deny"
        },
        "webfetch": "deny",
        "task": "deny"
      },
      "prompt": "{file:./.opencode/agents/db-design-impl.md}"
    },
    "service-comms": {
      "description": "Inter-service communication - gRPC proto definitions, RabbitMQ, API documentation, integration tests",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git push --force": "deny"
        },
        "webfetch": "deny",
        "task": "deny"
      },
      "prompt": "{file:./.opencode/agents/service-comms.md}"
    },
    "frontend-dev": {
      "description": "Frontend development - React/Next.js components, styling, state management, integration tests",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git push --force": "deny"
        },
        "webfetch": "deny",
        "task": "deny"
      },
      "prompt": "{file:./.opencode/agents/frontend-dev.md}"
    },
    "qa-specialist": {
      "description": "Code review and quality assurance - runs tests, validates coverage, checks code quality, auto-merges PRs",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "go test *": "allow",
          "npm test": "allow",
          "npm run build": "allow",
          "gh pr merge": "allow",
          "grep *": "allow"
        },
        "webfetch": "deny",
        "task": "deny"
      },
      "prompt": "{file:./.opencode/agents/qa-specialist.md}"
    }
  }
}
